generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id           String         @id @default(cuid())
  name         String
  slug         String         @unique
  description  String
  price        Float
  badge        String?
  isFeatured   Boolean        @default(false)
  createdAt    DateTime       @default(now())
  categoryId   String
  orderItems   OrderItem[]
  category     Category       @relation(fields: [categoryId], references: [id])
  Review       Review[]
  variants     Variant[]
  WishlistItem WishlistItem[]
}

model Category {
  id       String    @id @default(cuid())
  name     String
  slug     String    @unique
  image    String?
  products Product[]
}

model Variant {
  id        String  @id @default(cuid())
  color     String
  colorHex  String
  image     String
  stock     Int     @default(0)
  productId String
  product   Product @relation(fields: [productId], references: [id])
}

// ✅ النموذج الجديد - بدون User، يعتمد على userId محلي فقط
model GuestProfile {
  id      String  @id @default(cuid())
  userId  String  @unique   // crypto.randomUUID() من المتصفح
  name    String?
  phone   String?
  wilaya  String?
  address String?
}

model Order {
  id        String      @id @default(cuid())
  status    OrderStatus @default(PENDING)
  total     Float
  createdAt DateTime    @default(now())

  name      String
  phone     String
  wilaya    String
  address   String
  notes     String?

  // ✅ userId بسيط من localStorage - لا علاقة له بـ User model
  userId    String?

  items     OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  quantity  Int
  price     Float
  color     String
  orderId   String
  productId String
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  userId    String   // userId من localStorage
  productId String
  product   Product  @relation(fields: [productId], references: [id])
}

model WishlistItem {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String   // userId من localStorage
  productId String
  product   Product  @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}